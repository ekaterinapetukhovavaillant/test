{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "*/**",
    "!src/**"
  ],
  "plugins": [
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error",
    "style": "warn",
    "suspicious": "off",
    "pedantic": "off",
    "restriction": "off",
    "perf": "off"
  },
  "rules": {
    "prefer-const": "error",
    "eslint/no-unused-vars": "error",
    "sort-keys": "off",
    "no-magic-numbers": "off",
    "sort-imports": "off",
    "id-length": "off"
  }
}
